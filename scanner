-- Расшифровка и выполнение
local encrypted = ""
local function xorDecrypt(data, k)
    local result = ""
    for i = 1, #data do
        result = result .. string.char(string.byte(data, i) ~ string.byte(k, (i - 1) % #k + 1))
    end
    return result
end

